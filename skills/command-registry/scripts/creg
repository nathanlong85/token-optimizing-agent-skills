#!/usr/bin/env bash
set -Eeuo pipefail

VERSION="1.0.0"

# Resolve the real script path so template lookups keep working when
# `creg` is invoked through a symlink (e.g. ~/.local/bin/creg).
SELF_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SELF_PATH" ]]; do
  SELF_DIR="$(cd "$(dirname "$SELF_PATH")" && pwd -P)"
  SELF_TARGET="$(readlink "$SELF_PATH")"
  if [[ "$SELF_TARGET" == /* ]]; then
    SELF_PATH="$SELF_TARGET"
  else
    SELF_PATH="$SELF_DIR/$SELF_TARGET"
  fi
done

SCRIPT_DIR="$(cd "$(dirname "$SELF_PATH")" && pwd -P)"
SKILL_DIR="$(dirname "$SCRIPT_DIR")"

# Require bash 4.0+ for consistent behavior
if [[ "${BASH_VERSINFO[0]}" -lt 4 ]]; then
  echo "creg: requires bash 4.0 or later (found bash ${BASH_VERSION})" >&2
  echo "On macOS, install via: brew install bash" >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Global temp-file registry — safer than per-function RETURN traps, which
# overwrite the calling function's RETURN trap when set inside nested calls.
# ---------------------------------------------------------------------------
_CREG_TMPFILES=()
_cleanup_tmpfiles() {
  local f
  for f in "${_CREG_TMPFILES[@]+"${_CREG_TMPFILES[@]}"}"; do
    rm -f "$f"
  done
}
trap '_cleanup_tmpfiles' EXIT

creg_mktemp() {
  local f
  f=$(mktemp) || die "mktemp failed"
  _CREG_TMPFILES+=("$f")
  printf '%s' "$f"
}

# ---------------------------------------------------------------------------
# Registry path resolution
# ---------------------------------------------------------------------------

find_project_registry() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -d "$dir/.agents/rules/local/command-registry" ]]; then
      echo "$dir/.agents/rules/local/command-registry"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

find_global_registry() {
  if [[ -n "${CREG_GLOBAL_PATH:-}" ]]; then
    echo "$CREG_GLOBAL_PATH"
  else
    echo "$HOME/.agents/rules/command-registry"
  fi
}

get_registry() {
  local use_global="${1:-false}"
  if [[ "$use_global" == "true" ]]; then
    find_global_registry
  else
    local proj
    if proj=$(find_project_registry 2>/dev/null); then
      echo "$proj"
    else
      echo ".agents/rules/local/command-registry"
    fi
  fi
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

die() { printf 'creg: error: %s\n' "$*" >&2; exit 1; }
info() { printf '%s\n' "$*"; }

count_entries() {
  local dir="$1"
  if [[ ! -d "$dir" ]]; then echo 0; return; fi
  local count=0
  local f
  for f in "$dir"/*.md; do
    [[ -f "$f" ]] || continue
    [[ "$(basename "$f")" == "index.md" ]] && continue
    local n
    n=$(grep -c "^## " "$f" 2>/dev/null || true)
    count=$((count + n))
  done
  echo "$count"
}

# Parse --all and -g from "$@"; sets ALL_FLAG, GLOBAL_FLAG, REMAINING_ARGS
parse_all_flag() {
  ALL_FLAG="false"
  GLOBAL_FLAG="false"
  REMAINING_ARGS=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all) ALL_FLAG="true"; shift ;;
      -g|--global) GLOBAL_FLAG="true"; shift ;;
      *) REMAINING_ARGS+=("$1"); shift ;;
    esac
  done
}

# Invoke callback for each registry selected by ALL_FLAG / GLOBAL_FLAG.
creg_for_each_registry() {
  local callback="$1"
  if [[ "$ALL_FLAG" == "true" ]]; then
    "$callback" "$(get_registry "false")" "project"
    "$callback" "$(get_registry "true")"  "global"
  elif [[ "$GLOBAL_FLAG" == "true" ]]; then
    "$callback" "$(get_registry "true")" "global"
  else
    "$callback" "$(get_registry "false")" "project"
  fi
}

creg_plural_entries() {
  [[ "$1" -eq 1 ]] && printf 'entry' || printf 'entries'
}

list_entry_ids() {
  grep '^## ' "$1" 2>/dev/null | sed 's/^## //' || true
}

creg_extract_section_temp() {
  local file="$1" id="$2" section_file
  section_file=$(creg_mktemp)
  extract_section "$file" "$id" > "$section_file"
  printf '%s' "$section_file"
}

creg_install_section() {
  local registry="$1" topic="$2" block_file="$3"
  local topic_file="$registry/${topic}.md"
  if [[ ! -f "$topic_file" ]]; then
    cp "$block_file" "$topic_file"
    local index="$registry/index.md"
    [[ -f "$index" ]] && add_routing_row "$index" "$topic" "$topic_file"
  else
    insert_sorted "$topic_file" "$block_file"
  fi
}

# Find topic file containing an id; prints filepath or returns 1
find_entry_file() {
  local registry="$1" id="$2"
  [[ -d "$registry" ]] || return 1
  local f
  for f in "$registry"/*.md; do
    [[ -f "$f" ]] || continue
    [[ "$(basename "$f")" == "index.md" ]] && continue
    if grep -q "^## ${id}$" "$f" 2>/dev/null; then
      echo "$f"
      return 0
    fi
  done
  return 1
}

# Extract section: from ## id through the line before the next ## (or EOF)
extract_section() {
  local file="$1" id="$2"
  awk "/^## ${id}$/{found=1} found && /^## / && !/^## ${id}$/{exit} found{print}" "$file"
}

# Remove a ## id section from file (in-place)
remove_section() {
  local file="$1" id="$2"
  local tmp
  tmp=$(creg_mktemp)
  awk "
    /^## ${id}$/ { skip=1; next }
    skip && /^## / { skip=0 }
    !skip { print }
  " "$file" > "$tmp"
  mv "$tmp" "$file"
}

# Insert a section block (from a temp file) into $file at the A-Z sorted position
insert_sorted() {
  local file="$1"
  local block_file="$2"

  if [[ ! -s "$file" ]]; then
    cp "$block_file" "$file"
    return
  fi

  local new_id
  new_id=$(grep "^## " "$block_file" | sed 's/^## //')

  # Find which existing id comes after new_id alphabetically
  local insert_before=""
  local line
  while IFS= read -r line; do
    if [[ "$line" =~ ^##\ (.+)$ ]]; then
      local existing_id="${BASH_REMATCH[1]}"
      if [[ "$new_id" < "$existing_id" ]]; then
        insert_before="$existing_id"
        break
      fi
    fi
  done < "$file"

  if [[ -z "$insert_before" ]]; then
    { printf '\n'; cat "$block_file"; } >> "$file"
    return
  fi

  local tmp
  tmp=$(creg_mktemp)
  # Use awk getline to inject block_file before the target heading
  awk -v before="## ${insert_before}" -v blockfile="$block_file" '
    $0 == before && !done {
      while ((getline line < blockfile) > 0) print line
      close(blockfile)
      printf "\n"
      done = 1
    }
    { print }
  ' "$file" > "$tmp"
  mv "$tmp" "$file"
}

# Add a row to the routing table in index.md for a new topic
add_routing_row() {
  local index="$1" topic="$2" filepath="$3"
  local filename
  filename=$(basename "$filepath")
  # Skip if already present
  grep -q "$filename" "$index" 2>/dev/null && return 0
  local tmp
  tmp=$(creg_mktemp)
  awk -v row="| ${topic} | ${filename} |" '
    /^\|---/ && !inserted { print; print row; inserted=1; next }
    { print }
  ' "$index" > "$tmp"
  mv "$tmp" "$index"
}

# Remove routing table row matching filename
remove_routing_row() {
  local index="$1" filename="$2"
  local tmp
  tmp=$(creg_mktemp)
  grep -v "| ${filename} |" "$index" > "$tmp" || true
  mv "$tmp" "$index"
}

# ---------------------------------------------------------------------------
# Tag helpers
# ---------------------------------------------------------------------------

creg_tag_valid() {
  [[ "$1" =~ ^[a-z0-9][a-z0-9-]*$ ]]
}

# Parse comma/whitespace-separated tag input into CREG_TAGS_ARRAY (deduped, sorted).
creg_parse_tag_input() {
  local input="$1"
  local -a raw=()
  local token normalized
  CREG_TAGS_ARRAY=()
  normalized="${input//,/ }"
  for token in $normalized; do
    [[ -n "$token" ]] && raw+=("$token")
  done
  if [[ ${#raw[@]} -eq 0 ]]; then
    return 0
  fi
  local sorted
  sorted=$(printf '%s\n' "${raw[@]}" | awk '!seen[$0]++' | sort)
  while IFS= read -r token; do
    [[ -n "$token" ]] && CREG_TAGS_ARRAY+=("$token")
  done <<< "$sorted"
}

# Validate CREG_TAGS_ARRAY; die on invalid or duplicate tokens.
creg_validate_tags_array() {
  local tag
  for tag in "${CREG_TAGS_ARRAY[@]}"; do
    creg_tag_valid "$tag" || die "invalid tag '${tag}': tags must be lowercase alphanumeric with hyphens"
  done
}

creg_render_yaml_list() {
  local header="$1"
  shift
  [[ $# -gt 0 ]] || return 0
  printf '%s:\n' "$header"
  local item
  for item in "$@"; do
    printf -- '- %s\n' "$item"
  done
}

# Print canonical tags block to stdout.
creg_render_tags_block() {
  creg_render_yaml_list tags "${CREG_TAGS_ARRAY[@]}"
}

# Return 0 when needle is present in haystack array.
creg_array_contains() {
  local needle="$1"
  shift
  local item
  for item in "$@"; do
    [[ "$item" == "$needle" ]] && return 0
  done
  return 1
}

# Extract tags for one entry section file; prints one tag per line.
creg_entry_tags_from_section_file() {
  local section_file="$1"
  awk '
    function flush_inline(line,    parts, i, n) {
      sub(/^tags:[[:space:]]*/, "", line)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
      n = split(line, parts, /[,[:space:]]+/)
      for (i = 1; i <= n; i++) {
        if (parts[i] != "") print parts[i]
      }
    }
    /^tags:[[:space:]]+/ {
      flush_inline($0)
      next
    }
    /^tags:[[:space:]]*$/ {
      in_tags = 1
      next
    }
    in_tags && /^- / {
      tag = substr($0, 3)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", tag)
      if (tag != "") print tag
      next
    }
    in_tags && /^  - / {
      tag = substr($0, 5)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", tag)
      if (tag != "") print tag
      next
    }
    in_tags && /^[^[:space:]#-]/ {
      in_tags = 0
    }
  ' "$section_file"
}

# Return 0 when entry tags satisfy AND/ANY/EXCLUDE filters.
# Optional filter args default to SEARCH_* globals when omitted.
creg_entry_matches_tag_filters() {
  local section_file="$1"
  local filter_tags="${2:-${SEARCH_TAGS:-}}"
  local filter_any="${3:-${SEARCH_ANY_TAGS:-}}"
  local filter_exclude="${4:-${SEARCH_EXCLUDE_TAGS:-}}"
  local -a entry_tags=() required=() any=() exclude=()
  local tag req ex

  while IFS= read -r tag; do
    [[ -n "$tag" ]] && entry_tags+=("$tag")
  done < <(creg_entry_tags_from_section_file "$section_file")

  # creg_parse_tag_input clobbers the shared CREG_TAGS_ARRAY global each call;
  # copy it immediately into a local before the next call overwrites it.
  if [[ -n "$filter_tags" ]]; then
    creg_parse_tag_input "$filter_tags"
    required=("${CREG_TAGS_ARRAY[@]}")
    for req in "${required[@]}"; do
      creg_array_contains "$req" "${entry_tags[@]}" || return 1
    done
  fi

  if [[ -n "$filter_any" ]]; then
    creg_parse_tag_input "$filter_any"
    any=("${CREG_TAGS_ARRAY[@]}")
    local matched="false"
    for req in "${any[@]}"; do
      if creg_array_contains "$req" "${entry_tags[@]}"; then
        matched="true"
        break
      fi
    done
    [[ "$matched" == "true" ]] || return 1
  fi

  if [[ -n "$filter_exclude" ]]; then
    creg_parse_tag_input "$filter_exclude"
    exclude=("${CREG_TAGS_ARRAY[@]}")
    for ex in "${exclude[@]}"; do
      creg_array_contains "$ex" "${entry_tags[@]}" && return 1
    done
  fi

  return 0
}

# Return 0 when keyword matches anywhere in section (case-insensitive).
creg_section_matches_keyword() {
  local section_file="$1" keyword="$2"
  [[ -n "$keyword" ]] || return 0
  grep -qi "$keyword" "$section_file"
}

# Parse search flags; sets SEARCH_TAGS, SEARCH_ANY_TAGS, SEARCH_EXCLUDE_TAGS,
# ALL_FLAG, GLOBAL_FLAG, REMAINING_ARGS.
parse_search_flags() {
  SEARCH_TAGS=""
  SEARCH_ANY_TAGS=""
  SEARCH_EXCLUDE_TAGS=""
  ALL_FLAG="false"
  GLOBAL_FLAG="false"
  REMAINING_ARGS=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tags)          SEARCH_TAGS="$2";         shift 2 ;;
      --any-tags)      SEARCH_ANY_TAGS="$2";     shift 2 ;;
      --exclude-tags)  SEARCH_EXCLUDE_TAGS="$2"; shift 2 ;;
      --all)           ALL_FLAG="true";          shift ;;
      -g|--global)     GLOBAL_FLAG="true";       shift ;;
      *)               REMAINING_ARGS+=("$1");   shift ;;
    esac
  done
}

# Parse tags inventory flags.
parse_tags_flags() {
  TAGS_COUNTS="false"
  TAGS_UNTAGGED="false"
  ALL_FLAG="false"
  GLOBAL_FLAG="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --counts)      TAGS_COUNTS="true"; shift ;;
      --untagged)    TAGS_UNTAGGED="true"; shift ;;
      --all)         ALL_FLAG="true"; shift ;;
      -g|--global)   GLOBAL_FLAG="true"; shift ;;
      *) die "Unknown flag: $1" ;;
    esac
  done
}

# Parse upgrade-tags flags.
parse_upgrade_tags_flags() {
  UPGRADE_DRY_RUN="false"
  ALL_FLAG="false"
  GLOBAL_FLAG="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)     UPGRADE_DRY_RUN="true"; shift ;;
      --all)         ALL_FLAG="true"; shift ;;
      -g|--global)   GLOBAL_FLAG="true"; shift ;;
      *) die "Unknown flag: $1" ;;
    esac
  done
}

# Validate tags in one entry section; prints warnings/errors to stdout.
# Sets CREG_TAG_ISSUES count via global.
creg_validate_entry_tags() {
  local label="$1" file="$2" entry_id="$3" section_file="$4"
  local -a tags=() seen=()
  local tag issue=0
  local legacy_inline="false"

  if grep -q '^tags:[[:space:]]\+' "$section_file" 2>/dev/null; then
    legacy_inline="true"
  fi

  local in_tags_block="false" line
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^tags:[[:space:]]*$ ]]; then
      in_tags_block="true"
      continue
    fi
    if [[ "$in_tags_block" == "true" ]]; then
      if [[ "$line" =~ ^-[[:space:]]+[^[:space:]] ]] || [[ "$line" =~ ^\ \ -[[:space:]]+[^[:space:]] ]]; then
        continue
      fi
      if [[ "$line" =~ ^[[:space:]]*$ ]]; then
        continue
      fi
      if [[ "$line" =~ ^[^[:space:]#-] ]]; then
        in_tags_block="false"
        continue
      fi
      info "[${label}] ERROR: $(basename "$file"): entry '${entry_id}' has unsupported tags syntax '${line}'"
      issue=$((issue + 1))
    fi
  done < "$section_file"

  while IFS= read -r tag; do
    [[ -n "$tag" ]] && tags+=("$tag")
  done < <(creg_entry_tags_from_section_file "$section_file")

  for tag in "${tags[@]}"; do
    if ! creg_tag_valid "$tag"; then
      info "[${label}] ERROR: $(basename "$file"): entry '${entry_id}' has malformed tag '${tag}'"
      issue=$((issue + 1))
    fi
    if creg_array_contains "$tag" "${seen[@]}"; then
      info "[${label}] ERROR: $(basename "$file"): entry '${entry_id}' has duplicate tag '${tag}'"
      issue=$((issue + 1))
    else
      seen+=("$tag")
    fi
  done

  if [[ "$legacy_inline" == "true" ]]; then
    info "[${label}] WARNING: $(basename "$file"): entry '${entry_id}' uses legacy inline tags; run 'creg upgrade-tags' to normalize"
  fi

  CREG_TAG_ISSUES=$((CREG_TAG_ISSUES + issue))
}

# Rewrite legacy inline tags to canonical list form in-place for one registry.
creg_upgrade_tags_in_registry() {
  local registry="$1" label="$2"
  local total_changes=0 f

  [[ -d "$registry" ]] || return 0

  for f in "$registry"/*.md; do
    [[ -f "$f" ]] || continue
    [[ "$(basename "$f")" == "index.md" ]] && continue

    local tmp current_id="" file_changes=0
    tmp=$(creg_mktemp)
    : > "$tmp"

    while IFS= read -r line || [[ -n "$line" ]]; do
      if [[ "$line" =~ ^##\ (.+)$ ]]; then
        current_id="${BASH_REMATCH[1]}"
        printf '%s\n' "$line" >> "$tmp"
        continue
      fi

      if [[ -n "$current_id" && "$line" =~ ^tags:[[:space:]]+(.+)$ ]]; then
        local inline="${BASH_REMATCH[1]}"
        creg_parse_tag_input "$inline"
        {
          creg_render_tags_block
        } >> "$tmp"
        file_changes=$((file_changes + 1))
        if [[ "$UPGRADE_DRY_RUN" == "true" ]]; then
          info "[${label}] would upgrade tags for '${current_id}' in $(basename "$f")"
        fi
        continue
      fi

      printf '%s\n' "$line" >> "$tmp"
    done < "$f"

    if [[ "$file_changes" -gt 0 ]]; then
      total_changes=$((total_changes + file_changes))
      if [[ "$UPGRADE_DRY_RUN" == "false" ]]; then
        mv "$tmp" "$f"
      fi
    fi
  done

  if [[ "$total_changes" -eq 0 ]]; then
    info "[${label}] no legacy inline tags found"
  elif [[ "$UPGRADE_DRY_RUN" == "true" ]]; then
    info "[${label}] dry-run complete — ${total_changes} $(creg_plural_entries "$total_changes") would be upgraded"
  else
    info "[${label}] upgraded tags in ${total_changes} $(creg_plural_entries "$total_changes")"
  fi
}

# ---------------------------------------------------------------------------
# Bundle import/export helpers
# ---------------------------------------------------------------------------

CREG_BUNDLE_FORMAT="creg-bundle-v1"

creg_bundle_valid_name() {
  [[ "$1" =~ ^[a-z][a-z0-9_-]*$ ]]
}

creg_render_bundle_header() {
  local scope="$1"
  printf '# Command Registry Export\nformat: %s\nsource_scope: %s\n\n' "$CREG_BUNDLE_FORMAT" "$scope"
}

creg_entry_body_lines() {
  local section_file="$1"
  awk '
    NR == 1 && $0 ~ /^## / { next }
    $0 !~ /^registry_scope:/ { print }
  ' "$section_file"
}

creg_normalize_entry_text() {
  sed '/^[[:space:]]*$/d' | sed 's/[[:space:]]*$//'
}

creg_normalize_entry_body_file() {
  local section_file="$1"
  creg_entry_body_lines "$section_file" | creg_normalize_entry_text
}

creg_render_bundle_entry() {
  local topic="$1" id="$2" section_file="$3" scope_label="${4:-}"
  printf '## %s/%s\n' "$topic" "$id"
  [[ -n "$scope_label" ]] && printf 'registry_scope: %s\n' "$scope_label"
  creg_entry_body_lines "$section_file"
  printf '\n'
}

creg_validate_bundle_entry_body() {
  local topic="$1" id="$2" body_file="$3"
  creg_bundle_valid_name "$topic" || die "invalid bundle topic '${topic}'"
  creg_bundle_valid_name "$id" || die "invalid bundle id '${id}'"
  grep -q '^intent:' "$body_file" || die "bundle entry '${topic}/${id}' missing intent:"
  grep -q '^verified:\|^template:' "$body_file" || die "bundle entry '${topic}/${id}' missing verified: or template:"
}

creg_bundle_load() {
  local bundle_file="$1"
  local manifest_file="$2"
  local work_dir="${manifest_file}.entries"

  [[ -f "$bundle_file" ]] || die "bundle file not found: $bundle_file"
  grep -Eq '^format:[[:space:]]*creg-bundle-v1[[:space:]]*$' "$bundle_file" \
    || die "unsupported or missing bundle format (expected format: creg-bundle-v1)"

  rm -rf "$work_dir"
  mkdir -p "$work_dir"
  : > "$manifest_file"

  awk -v manifest="$manifest_file" -v workdir="$work_dir" '
    /^## / {
      if (entry > 0) close(bodyfile)
      line = substr($0, 4)
      n = split(line, parts, "/")
      if (n != 2) {
        print "creg: error: invalid bundle heading (expected ## topic/id): " $0 > "/dev/stderr"
        exit 3
      }
      entry++
      topic = parts[1]
      id = parts[2]
      bodyfile = workdir "/" entry ".section"
      print topic "|" id "|" bodyfile >> manifest
      next
    }
    entry > 0 && $0 !~ /^#/ {
      if ($0 ~ /^registry_scope:/) next
      print >> bodyfile
    }
  ' "$bundle_file"
}

creg_import_classify() {
  local registry="$1" topic="$2" id="$3" body_file="$4"
  local existing_file existing_body norm_new norm_old

  if ! existing_file=$(find_entry_file "$registry" "$id" 2>/dev/null); then
    printf 'new'
    return 0
  fi

  existing_body=$(creg_extract_section_temp "$existing_file" "$id")
  norm_new=$(creg_normalize_entry_text < "$body_file")
  norm_old=$(creg_normalize_entry_body_file "$existing_body")
  if [[ "$norm_new" == "$norm_old" ]]; then
    printf 'identical'
  else
    printf 'conflict'
  fi
}

creg_write_registry_entry() {
  local registry="$1" topic="$2" id="$3" body_file="$4" replace="${5:-false}"
  local topic_file="$registry/${topic}.md"
  local block_file
  block_file=$(creg_mktemp)
  {
    printf '## %s\n\n' "$id"
    cat "$body_file"
  } > "$block_file"

  if [[ "$replace" == "true" ]]; then
    remove_section "$topic_file" "$id"
  fi

  creg_install_section "$registry" "$topic" "$block_file"
}

creg_entry_matches_export_filters() {
  local topic="$1" id="$2" section_file="$3"
  [[ -z "$EXPORT_TOPIC" || "$EXPORT_TOPIC" == "$topic" ]] || return 1
  [[ -z "$EXPORT_ID" || "$EXPORT_ID" == "$id" ]] || return 1
  if [[ "$EXPORT_VERIFIED_ONLY" == "true" ]]; then
    grep -q '^verified:' "$section_file" || return 1
  fi
  if [[ -n "$EXPORT_TAGS" ]]; then
    creg_entry_matches_tag_filters "$section_file" "$EXPORT_TAGS" || return 1
  fi
  return 0
}

parse_export_flags() {
  EXPORT_TOPIC=""
  EXPORT_ID=""
  EXPORT_TAGS=""
  EXPORT_VERIFIED_ONLY="false"
  EXPORT_OUTPUT=""
  ALL_FLAG="false"
  GLOBAL_FLAG="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --topic)           EXPORT_TOPIC="$2";          shift 2 ;;
      --id)              EXPORT_ID="$2";             shift 2 ;;
      --tags)            EXPORT_TAGS="$2";           shift 2 ;;
      --verified-only)   EXPORT_VERIFIED_ONLY="true"; shift ;;
      --output)          EXPORT_OUTPUT="$2";         shift 2 ;;
      --all)             ALL_FLAG="true";            shift ;;
      -g|--global)       GLOBAL_FLAG="true";         shift ;;
      *) die "Unknown flag: $1" ;;
    esac
  done
}

parse_import_flags() {
  IMPORT_APPLY="false"
  IMPORT_MERGE="false"
  IMPORT_OVERWRITE="false"
  IMPORT_RENAME="false"
  GLOBAL_FLAG="false"
  IMPORT_FILE=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --apply)             IMPORT_APPLY="true"; shift ;;
      --merge)             IMPORT_MERGE="true"; shift ;;
      --overwrite)         IMPORT_OVERWRITE="true"; shift ;;
      --rename-conflicts)  IMPORT_RENAME="true"; shift ;;
      -g|--global)         GLOBAL_FLAG="true"; shift ;;
      -*) die "Unknown flag: $1" ;;
      *)
        [[ -z "$IMPORT_FILE" ]] || die "Usage: creg import <file> [--apply] [--merge|--overwrite|--rename-conflicts] [-g]"
        IMPORT_FILE="$1"
        shift
        ;;
    esac
  done
  [[ -n "$IMPORT_FILE" ]] || die "Usage: creg import <file> [--apply] [--merge|--overwrite|--rename-conflicts] [-g]"
}

_creg_export_registry() {
  local registry="$1" scope_label="$2" include_scope="${3:-false}"
  [[ -d "$registry" ]] || return 0

  local f topic id section_file
  for f in "$registry"/*.md; do
    [[ -f "$f" ]] || continue
    [[ "$(basename "$f")" == "index.md" ]] && continue
    topic=$(basename "$f" .md)

    while IFS= read -r id; do
      [[ -n "$id" ]] || continue
      section_file=$(creg_extract_section_temp "$f" "$id")
      creg_entry_matches_export_filters "$topic" "$id" "$section_file" || continue
      if [[ "$include_scope" == "true" ]]; then
        creg_render_bundle_entry "$topic" "$id" "$section_file" "$scope_label"
      else
        creg_render_bundle_entry "$topic" "$id" "$section_file"
      fi
    done < <(list_entry_ids "$f")
  done
}

cmd_export() {
  parse_export_flags "$@"

  local sink="/dev/stdout"
  [[ -z "$EXPORT_OUTPUT" ]] || sink="$EXPORT_OUTPUT"

  {
    if [[ "$ALL_FLAG" == "true" ]]; then
      creg_render_bundle_header "all"
      _creg_export_registry "$(get_registry "false")" "project" "true"
      _creg_export_registry "$(get_registry "true")"  "global"  "true"
    elif [[ "$GLOBAL_FLAG" == "true" ]]; then
      creg_render_bundle_header "global"
      _creg_export_registry "$(get_registry "true")" "global" "false"
    else
      creg_render_bundle_header "project"
      _creg_export_registry "$(get_registry "false")" "project" "false"
    fi
  } > "$sink"

  if [[ -n "$EXPORT_OUTPUT" ]]; then
    info "Exported bundle: $EXPORT_OUTPUT"
  fi
}

cmd_import() {
  parse_import_flags "$@"

  local registry manifest_file
  registry=$(get_registry "$GLOBAL_FLAG")
  [[ -d "$registry" ]] || die "Registry not initialized: $registry. Run 'creg init' first."

  manifest_file=$(creg_mktemp)
  creg_bundle_load "$IMPORT_FILE" "$manifest_file"

  local -a topics=() ids=() bodies=() statuses=()
  local topic id body_file status renamed_id
  while IFS='|' read -r topic id body_file; do
    [[ -n "$topic" ]] || continue
    creg_validate_bundle_entry_body "$topic" "$id" "$body_file"
    status=$(creg_import_classify "$registry" "$topic" "$id" "$body_file")
    topics+=("$topic")
    ids+=("$id")
    bodies+=("$body_file")
    statuses+=("$status")
    info "${status}: ${topic}/${id}"
  done < "$manifest_file"

  local apply_cmd="creg import ${IMPORT_FILE}"
  [[ "$GLOBAL_FLAG" == "true" ]] && apply_cmd+=" -g"
  apply_cmd+=" --apply"

  if [[ "$IMPORT_APPLY" != "true" ]]; then
    info ""
    info "Preview only (no changes made). To apply:"
    info "  ${apply_cmd}"
    return 0
  fi

  local conflict_count=0
  local i
  for i in "${!statuses[@]}"; do
    [[ "${statuses[$i]}" == "conflict" ]] && conflict_count=$((conflict_count + 1))
  done

  if [[ "$conflict_count" -gt 0 && "$IMPORT_MERGE" != "true" && "$IMPORT_OVERWRITE" != "true" && "$IMPORT_RENAME" != "true" ]]; then
    die "import blocked: ${conflict_count} conflicting $(creg_plural_entries "$conflict_count"). Re-run with --merge, --overwrite, or --rename-conflicts"
  fi

  if [[ "$IMPORT_RENAME" == "true" ]]; then
    for i in "${!statuses[@]}"; do
      [[ "${statuses[$i]}" != "conflict" ]] && continue
      renamed_id="${ids[$i]}_imported"
      if find_entry_file "$registry" "$renamed_id" >/dev/null 2>&1; then
        die "rename-conflicts failed: '${renamed_id}' already exists"
      fi
    done
  fi

  for i in "${!statuses[@]}"; do
    topic="${topics[$i]}"
    id="${ids[$i]}"
    body_file="${bodies[$i]}"
    status="${statuses[$i]}"

    case "$status" in
      identical)
        info "skipped identical: ${id}"
        ;;
      new)
        creg_write_registry_entry "$registry" "$topic" "$id" "$body_file" "false"
        info "imported: ${id}"
        ;;
      conflict)
        if [[ "$IMPORT_OVERWRITE" == "true" ]]; then
          creg_write_registry_entry "$registry" "$topic" "$id" "$body_file" "true"
          info "overwritten: ${id}"
        elif [[ "$IMPORT_RENAME" == "true" ]]; then
          renamed_id="${id}_imported"
          creg_write_registry_entry "$registry" "$topic" "$renamed_id" "$body_file" "false"
          info "imported as: ${renamed_id}"
        else
          info "skipped conflict: ${id}"
        fi
        ;;
    esac
  done
}

# ---------------------------------------------------------------------------
# Canonical activation snippet
# ---------------------------------------------------------------------------

# shellcheck disable=SC2016  # intentional: $CREG_GLOBAL_PATH should not expand here
ACTIVATION_SNIPPET='## Command Registry

Before running or suggesting any shell command — and before retrying after a failure —
check command registries (use whichever exist):

1. Project: .agents/rules/local/command-registry/ (if present)
2. Global: ~/.agents/rules/command-registry/ (or $CREG_GLOBAL_PATH if set)
Project wins on conflicts. For each registry found:
  a. Identify the right topic file from index.md routing table.
  b. Search (grep/rg) for the `## snake_case_id` or keyword. Read only that section.
     For precise tag filtering: `creg search --tags tag1[,tag2]` (or `--any-tags`, `--exclude-tags`).
  c. Prefer: exact verified → adapt template → closest intent.
  d. If retrying after a failure, re-scan `anti_patterns` in the matched entry before changing command shape.

After a command succeeds that is not in the registry: use `creg add` to record it that turn.
  - Contains project-specific path/host/script → project registry (no -g)
  - Generic, works across repos → global registry (creg add ... -g)
  Print one line to the user: `Command registry: added <id>` or `Command registry: updated <id>`.

Extend existing entries. Avoid near-duplicates across topic files.
Registry wins for command shape. Project rules win for policy.'

SNIPPET_MARKER="## Command Registry"

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

cmd_init() {
  parse_all_flag "$@"
  [[ "$ALL_FLAG" == "true" ]] && die "'--all' is not supported for 'init'"
  local registry
  registry=$(get_registry "$GLOBAL_FLAG")
  if [[ -f "$registry/index.md" ]]; then
    info "Already initialized: $registry/index.md (no changes made)"
    return 0
  fi
  mkdir -p "$registry"
  cp "$SKILL_DIR/template/index.md" "$registry/index.md"
  info "Initialized registry: $registry"
}

cmd_inject() {
  [[ $# -eq 0 ]] && die "Usage: creg inject <file...>"
  local f
  for f in "$@"; do
    if [[ -f "$f" ]] && grep -qF "$SNIPPET_MARKER" "$f" 2>/dev/null; then
      info "$f: already contains activation snippet (no changes)"
      continue
    fi

    if [[ "$f" == *.mdc ]]; then
      if [[ ! -f "$f" ]]; then
        printf -- '---\nalwaysApply: true\n---\n\n%s\n' "$ACTIVATION_SNIPPET" > "$f"
      else
        if grep -q "^---" "$f" 2>/dev/null; then
          if ! grep -q "alwaysApply" "$f" 2>/dev/null; then
            local tmp
            tmp=$(creg_mktemp)
            awk '/^---$/ && !done { print; print "alwaysApply: true"; done=1; next } { print }' "$f" > "$tmp"
            mv "$tmp" "$f"
          fi
        else
          local tmp2
          tmp2=$(creg_mktemp)
          printf -- '---\nalwaysApply: true\n---\n\n' > "$tmp2"
          cat "$f" >> "$tmp2"
          mv "$tmp2" "$f"
        fi
        printf '\n%s\n' "$ACTIVATION_SNIPPET" >> "$f"
      fi
    else
      if [[ ! -f "$f" ]]; then
        printf '%s\n' "$ACTIVATION_SNIPPET" > "$f"
      else
        printf '\n%s\n' "$ACTIVATION_SNIPPET" >> "$f"
      fi
    fi
    info "$f: activation snippet added"
  done
}

cmd_link() {
  local target="${1:-}"
  [[ "$target" == "--cursor" ]] || die "Usage: creg link --cursor"

  local proj_registry
  proj_registry=$(find_project_registry 2>/dev/null) || die "No project registry found. Run 'creg init' first."

  # Walk up: proj_registry is <root>/.agents/rules/local/command-registry (4 levels)
  local repo_root
  repo_root=$(dirname "$(dirname "$(dirname "$(dirname "$proj_registry")")")")
  local link_dir="$repo_root/.cursor/rules/local"
  local link_path="$link_dir/command-registry"

  if [[ -L "$link_path" ]]; then
    info "Symlink already exists: $link_path (no changes)"
    return 0
  fi

  mkdir -p "$link_dir"
  ln -s "$proj_registry" "$link_path"
  info "Symlink created: $link_path → $proj_registry"
}

cmd_add() {
  local topic="${1:-}" id="${2:-}"
  [[ -n "$topic" ]] || die "Usage: creg add <topic> <id> --intent \"...\" [options]"
  [[ -n "$id" ]] || die "Usage: creg add <topic> <id> --intent \"...\" [options]"
  shift 2

  local intent="" tags="" verified="" template=""
  local -a variants=() anti_patterns=() CREG_TAGS_ARRAY=()
  GLOBAL_FLAG="false"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --intent)      intent="$2";          shift 2 ;;
      --tags)        tags="$2";            shift 2 ;;
      --verified)    verified="$2";        shift 2 ;;
      --template)    template="$2";        shift 2 ;;
      --variant)     variants+=("$2");     shift 2 ;;
      --anti-pattern) anti_patterns+=("$2"); shift 2 ;;
      -g|--global)   GLOBAL_FLAG="true";   shift ;;
      *) die "Unknown flag: $1" ;;
    esac
  done

  [[ -n "$intent" ]]                            || die "--intent is required"
  [[ -n "$verified" || -n "$template" ]]        || die "At least one of --verified or --template is required"

  if [[ -n "$tags" ]]; then
    creg_parse_tag_input "$tags"
    creg_validate_tags_array
  fi

  local registry
  registry=$(get_registry "$GLOBAL_FLAG")
  [[ -d "$registry" ]] || die "Registry not initialized: $registry. Run 'creg init' first."

  # Dedup check across all topic files
  local existing_file
  if existing_file=$(find_entry_file "$registry" "$id" 2>/dev/null); then
    die "id '${id}' already exists in $(basename "$existing_file"). Use 'creg move' to relocate or extend the existing entry."
  fi

  # Write block to a temp file (avoids awk -v newline issues)
  local block_file
  block_file=$(creg_mktemp)

  {
    printf '## %s\n\n' "$id"
    printf 'intent: %s\n' "$intent"
    if [[ ${#CREG_TAGS_ARRAY[@]} -gt 0 ]]; then
      creg_render_tags_block
    fi
    [[ -n "$verified" ]] && printf 'verified: %s\n' "$verified"
    [[ -n "$template" ]] && printf 'template: %s\n' "$template"
    creg_render_yaml_list variants "${variants[@]}"
    creg_render_yaml_list anti_patterns "${anti_patterns[@]}"
  } > "$block_file"

  creg_install_section "$registry" "$topic" "$block_file"

  info "Command registry: added ${id}"
}

cmd_move() {
  parse_all_flag "$@"
  [[ "$ALL_FLAG" == "true" ]] && die "'--all' is not supported for 'move'"
  set -- "${REMAINING_ARGS[@]}"
  local id="${1:-}" new_topic="${2:-}"
  [[ -n "$id" ]]        || die "Usage: creg move <id> <new-topic> [-g]"
  [[ -n "$new_topic" ]] || die "Usage: creg move <id> <new-topic> [-g]"

  local registry
  registry=$(get_registry "$GLOBAL_FLAG")
  [[ -d "$registry" ]] || die "Registry not found: $registry"

  local src_file
  src_file=$(find_entry_file "$registry" "$id") || die "id '${id}' not found in registry: $registry"

  local section_file
  section_file=$(creg_extract_section_temp "$src_file" "$id")

  remove_section "$src_file" "$id"
  creg_install_section "$registry" "$new_topic" "$section_file"

  # Delete source if no entries remain
  local remaining
  remaining=$(grep -c "^## " "$src_file" 2>/dev/null || true)
  if [[ "$remaining" -eq 0 ]]; then
    local src_basename
    src_basename=$(basename "$src_file")
    rm "$src_file"
    local index="$registry/index.md"
    [[ -f "$index" ]] && remove_routing_row "$index" "$src_basename"
    info "Deleted empty topic file: $src_basename"
  fi

  info "Moved '${id}' to ${new_topic}.md"
}

cmd_search() {
  parse_search_flags "$@"
  set -- "${REMAINING_ARGS[@]}"
  local keyword="${1:-}"

  if [[ -z "$keyword" && -z "$SEARCH_TAGS" && -z "$SEARCH_ANY_TAGS" && -z "$SEARCH_EXCLUDE_TAGS" ]]; then
    die "Usage: creg search [<keyword>] [--tags <tags>] [--any-tags <tags>] [--exclude-tags <tags>] [-g] [--all]"
  fi

  _search_one_registry() {
    local registry="$1" label="$2"
    if [[ ! -d "$registry" ]]; then
      info "[${label}] not present: $registry"
      return
    fi

    local found=0 f id section_file
    for f in "$registry"/*.md; do
      [[ -f "$f" ]] || continue
      [[ "$(basename "$f")" == "index.md" ]] && continue

      local topic matched_in_file=0
      topic=$(basename "$f" .md)

      while IFS= read -r id; do
        [[ -n "$id" ]] || continue
        section_file=$(creg_extract_section_temp "$f" "$id")

        if ! creg_entry_matches_tag_filters "$section_file"; then
          continue
        fi
        if ! creg_section_matches_keyword "$section_file" "$keyword"; then
          continue
        fi

        if [[ "$matched_in_file" -eq 0 ]]; then
          info "[${label}: $(basename "$f")]"
          matched_in_file=1
        fi
        info "  ## ${id}"
        found=1
      done < <(list_entry_ids "$f")

    done

    if [[ "$found" -eq 0 ]]; then
      if [[ -n "$keyword" ]]; then
        info "[${label}] no matches for '${keyword}'"
      else
        info "[${label}] no matches for tag filter"
      fi
    fi
  }

  creg_for_each_registry _search_one_registry
}

cmd_tags() {
  parse_tags_flags "$@"

  _tags_one_registry() {
    local registry="$1" label="$2"
    if [[ ! -d "$registry" ]]; then
      info "[${label}] not present: $registry"
      return
    fi

    local -A tag_counts=()
    local untagged=0 f id section_file tag

    for f in "$registry"/*.md; do
      [[ -f "$f" ]] || continue
      [[ "$(basename "$f")" == "index.md" ]] && continue
      local topic
      topic=$(basename "$f" .md)

      while IFS= read -r id; do
        [[ -n "$id" ]] || continue
        section_file=$(creg_extract_section_temp "$f" "$id")
        local has_tags=0
        while IFS= read -r tag; do
          [[ -n "$tag" ]] || continue
          has_tags=1
          tag_counts["$tag"]=$(( ${tag_counts["$tag"]:-0} + 1 ))
        done < <(creg_entry_tags_from_section_file "$section_file")
        if [[ "$TAGS_UNTAGGED" == "true" && "$has_tags" -eq 0 ]]; then
          info "  ${topic}/${id}"
          untagged=$((untagged + 1))
        fi
      done < <(list_entry_ids "$f")
    done

    if [[ "$TAGS_UNTAGGED" == "true" ]]; then
      [[ "$untagged" -gt 0 ]] || info "[${label}] all entries are tagged"
      return
    fi

    info "[${label}] $registry"
    if [[ ${#tag_counts[@]} -eq 0 ]]; then
      info "  (no tags)"
      return
    fi

    local sorted_tag
    while IFS= read -r sorted_tag; do
      [[ -n "$sorted_tag" ]] || continue
      if [[ "$TAGS_COUNTS" == "true" ]]; then
        info "  ${sorted_tag} (${tag_counts[$sorted_tag]})"
      else
        info "  ${sorted_tag}"
      fi
    done < <(printf '%s\n' "${!tag_counts[@]}" | sort)
  }

  creg_for_each_registry _tags_one_registry
}

cmd_upgrade_tags() {
  parse_upgrade_tags_flags "$@"

  creg_for_each_registry creg_upgrade_tags_in_registry
}

cmd_show() {
  parse_all_flag "$@"
  set -- "${REMAINING_ARGS[@]}"
  local id="${1:-}"
  [[ -n "$id" ]] || die "Usage: creg show <id>"

  _show_in_registry() {
    local registry="$1"
    [[ -d "$registry" ]] || return 1
    local file
    if file=$(find_entry_file "$registry" "$id"); then
      extract_section "$file" "$id"
      return 0
    fi
    return 1
  }

  if [[ "$ALL_FLAG" == "true" || "$GLOBAL_FLAG" == "false" ]]; then
    local proj
    proj=$(get_registry "false")
    if _show_in_registry "$proj"; then return 0; fi
    if [[ "$ALL_FLAG" == "true" ]]; then
      _show_in_registry "$(get_registry "true")" && return 0
    fi
  else
    _show_in_registry "$(get_registry "true")" && return 0
  fi
  die "id '${id}' not found in any searched registry"
}

cmd_list() {
  parse_all_flag "$@"

  _list_one_registry() {
    local registry="$1" label="$2"
    if [[ ! -d "$registry" ]]; then
      info "[${label}] not present: $registry"
      return
    fi
    info "[${label}] $registry"
    local f topic
    for f in "$registry"/*.md; do
      [[ -f "$f" ]] || continue
      [[ "$(basename "$f")" == "index.md" ]] && continue
      topic=$(basename "$f" .md)
      grep "^## " "$f" | sed "s/^## /  ${topic}\//g" 2>/dev/null || true
    done
  }

  creg_for_each_registry _list_one_registry
}

cmd_validate() {
  parse_all_flag "$@"

  local exit_code=0

  _validate_one_registry() {
    local registry="$1" label="$2"
    if [[ ! -d "$registry" ]]; then
      info "[${label}] not present: $registry (skipping)"
      return
    fi

    local errors=0
    CREG_TAG_ISSUES=0
    local -A CREG_SEEN_IDS=()

    _validate_tags_for_entry() {
      local entry_id="$1"
      [[ -n "$entry_id" ]] || return 0
      creg_validate_entry_tags "$label" "$f" "$entry_id" "$(creg_extract_section_temp "$f" "$entry_id")"
    }

    _validate_entry_fields() {
      local entry_id="$1"
      [[ -n "$entry_id" ]] || return 0
      if [[ "$has_intent" == "false" ]]; then
        info "[${label}] ERROR: $(basename "$f"): entry '${entry_id}' missing 'intent:'"
        errors=$((errors + 1))
      fi
      if [[ "$has_cmd" == "false" ]]; then
        info "[${label}] ERROR: $(basename "$f"): entry '${entry_id}' missing both 'verified:' and 'template:'"
        errors=$((errors + 1))
      fi
      _validate_tags_for_entry "$entry_id"
    }

    local f
    for f in "$registry"/*.md; do
      [[ -f "$f" ]] || continue
      [[ "$(basename "$f")" == "index.md" ]] && continue

      local current_id="" has_intent="false" has_cmd="false" line
      while IFS= read -r line; do
        if [[ "$line" =~ ^##\ (.+)$ ]]; then
          local next_id="${BASH_REMATCH[1]}"
          _validate_entry_fields "$current_id"
          current_id="$next_id"
          has_intent="false"
          has_cmd="false"

          if [[ -v CREG_SEEN_IDS[$current_id] ]]; then
            info "[${label}] ERROR: duplicate id '${current_id}' in $(basename "$f") and $(basename "${CREG_SEEN_IDS[$current_id]}")"
            errors=$((errors + 1))
          else
            CREG_SEEN_IDS[$current_id]="$f"
          fi
        elif [[ "$line" =~ ^intent: ]]; then
          has_intent="true"
        elif [[ "$line" =~ ^(verified|template): ]]; then
          has_cmd="true"
        fi
      done < "$f"

      _validate_entry_fields "$current_id"
    done

    errors=$((errors + CREG_TAG_ISSUES))

    # Routing-table drift checks
    local index="$registry/index.md"
    if [[ -f "$index" ]]; then
      # Rows pointing to missing files
      local fname
      while IFS= read -r fname; do
        [[ -n "$fname" ]] || continue
        if [[ ! -f "$registry/$fname" ]]; then
          info "[${label}] ERROR: routing table references missing file: $fname"
          errors=$((errors + 1))
        fi
      done < <(grep "^| " "$index" | grep -v "^| Task\|^|---" | awk -F'|' '{gsub(/[[:space:]]/, "", $3); if ($3 != "") print $3}')

      # Topic files not listed in routing table
      for f in "$registry"/*.md; do
        [[ -f "$f" ]] || continue
        local bname
        bname=$(basename "$f")
        [[ "$bname" == "index.md" ]] && continue
        if ! grep -q "$bname" "$index" 2>/dev/null; then
          info "[${label}] ERROR: topic file '${bname}' not listed in routing table"
          errors=$((errors + 1))
        fi
      done
    fi

    if [[ "$errors" -eq 0 ]]; then
      info "[${label}] OK — ${#CREG_SEEN_IDS[@]} entries, no issues found"
    else
      exit_code=1
    fi
  }

  creg_for_each_registry _validate_one_registry

  return $exit_code
}

cmd_status() {
  local proj_registry glob_registry
  proj_registry=$(get_registry "false")
  glob_registry=$(get_registry "true")

  info "=== Command Registry Status ==="
  info ""

  if [[ -d "$proj_registry" ]]; then
    info "Project registry:"
    info "  Path:    $proj_registry"
    info "  Entries: $(count_entries "$proj_registry")"
  else
    info "Project registry: not initialized"
    info "  Expected: $proj_registry"
    info "  Run 'creg init' to create"
  fi

  info ""

  if [[ -d "$glob_registry" ]]; then
    info "Global registry:"
    if [[ -n "${CREG_GLOBAL_PATH:-}" ]]; then
      info "  Path:    $glob_registry (via \$CREG_GLOBAL_PATH)"
    else
      info "  Path:    $glob_registry"
    fi
    info "  Entries: $(count_entries "$glob_registry")"
  else
    info "Global registry: not initialized"
    if [[ -n "${CREG_GLOBAL_PATH:-}" ]]; then
      info "  Expected: $glob_registry (via \$CREG_GLOBAL_PATH)"
    else
      info "  Expected: $glob_registry"
    fi
    info "  Run 'creg init -g' to create"
  fi
}

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------

usage() {
  cat <<'EOF'
creg — command registry CLI

Usage: creg <subcommand> [options]

Bootstrap
  init [-g]                       Create registry directory + index.md from template
  inject <file...>                Append activation snippet to rules files (.mdc gets frontmatter)
  link --cursor                   Create .cursor/rules/local/command-registry → project registry symlink

Write
  add <topic> <id> [flags] [-g]   Add a new entry to a topic file
    --intent "..."    (required)
    --tags "..."
    --verified "..."  (required if no --template)
    --template "..."  (required if no --verified)
    --variant "..."   (repeatable)
    --anti-pattern "..."  (repeatable)

Read
  search [<keyword>] [flags]     Search by id/intent/verified/template or exact tags
    --tags <tags>                Require all listed tags (comma-separated)
    --any-tags <tags>            Match any listed tag
    --exclude-tags <tags>        Exclude entries with listed tags
  tags [--counts] [--untagged]   List tag vocabulary (or counts / untagged entries)
  show <id> [-g] [--all]          Print a single entry section
  list [-g] [--all]               List all entries

Import / Export
  export [flags]                Write a creg-bundle-v1 markdown bundle
    --topic <topic>             Export one topic file
    --id <id>                   Export one entry id
    --tags <tags>               Export entries matching all tags
    --verified-only             Omit entries without verified:
    --output <file>             Write bundle to file (default: stdout)
  import <file> [flags]         Preview or apply a bundle import (preview by default)
    --apply                     Write imported entries to the registry
    --merge                     Apply new entries; skip conflicts
    --overwrite                 Replace conflicting entries
    --rename-conflicts          Import conflicts as <id>_imported

Maintenance
  move <id> <new-topic> [-g]      Relocate entry between topic files
  upgrade-tags [--dry-run]        Convert legacy inline tags to canonical lists
  validate [-g] [--all]           Check schema, dedup, tags, and routing-table consistency
  status                          Show registry paths and entry counts

Flags
  -g, --global    Target global registry (~/.agents/rules/command-registry or $CREG_GLOBAL_PATH)
  --all           Operate on both registries simultaneously
  --version       Print version
  --help          Print this help

EOF
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

[[ $# -eq 0 ]] && usage && exit 0

case "$1" in
  --version|-v) printf 'creg %s\n' "$VERSION"; exit 0 ;;
  --help|-h)    usage; exit 0 ;;
  init)     shift; cmd_init    "$@" ;;
  inject)   shift; cmd_inject  "$@" ;;
  link)     shift; cmd_link    "$@" ;;
  add)      shift; cmd_add     "$@" ;;
  move)     shift; cmd_move    "$@" ;;
  search)   shift; cmd_search  "$@" ;;
  tags)     shift; cmd_tags    "$@" ;;
  show)     shift; cmd_show    "$@" ;;
  list)     shift; cmd_list    "$@" ;;
  export)   shift; cmd_export  "$@" ;;
  import)   shift; cmd_import  "$@" ;;
  validate) shift; cmd_validate "$@" ;;
  upgrade-tags) shift; cmd_upgrade_tags "$@" ;;
  status)   cmd_status ;;
  *)        die "Unknown subcommand: $1. Run 'creg --help' for usage." ;;
esac
